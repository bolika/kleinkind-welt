{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kleinkind-welt.de/data/content-brief.schema.json",
  "title": "Kleinkind-Welt Content Brief",
  "type": "object",
  "required": [
    "schemaVersion",
    "slug",
    "status",
    "primaryQuery",
    "searchIntent",
    "sources",
    "claims",
    "reviewDueAt",
    "humanApproval"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "status": { "enum": ["draft", "review_required", "approved", "published"] },
    "publishReady": { "type": "boolean" },
    "primaryQuery": { "type": "string", "minLength": 3 },
    "searchIntent": { "enum": ["informational", "commercial", "transactional", "navigational", "mixed"] },
    "targetAudience": { "type": "string" },
    "uniqueValue": { "type": "string" },
    "reviewDueAt": { "type": "string", "format": "date" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "url", "kind", "checkedAt"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "kind": { "enum": ["primary", "official", "study", "manufacturer", "retailer", "editorial", "reviews"] },
          "checkedAt": { "type": "string", "format": "date" }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "text", "sourceIds", "approvedForPublish"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["safety", "development", "product_fact", "editorial", "commercial"] },
          "text": { "type": "string" },
          "sourceIds": { "type": "array", "items": { "type": "string" } },
          "approvedForPublish": { "type": "boolean" }
        }
      }
    },
    "humanApproval": {
      "type": "object",
      "required": ["required", "approvedBy", "approvedAt"],
      "properties": {
        "required": { "type": "boolean" },
        "approvedBy": { "type": ["string", "null"] },
        "approvedAt": { "type": ["string", "null"], "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}
