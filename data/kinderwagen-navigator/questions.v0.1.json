{
  "schemaVersion": 1,
  "modelVersion": "0.1.0",
  "flowVersion": "0.2.0",
  "designRules": {
    "oneQuestionPerScreen": true,
    "showBackButton": true,
    "showAnswerSummaryBeforeResult": false,
    "estimatedQuestions": "5 Kernfragen, bei regelmäßigem Tragen eine Zusatzfrage",
    "doNotPromiseDurationUntilMeasured": true
  },
  "questions": [
    {
      "id": "search_goal",
      "order": 0,
      "type": "single_choice",
      "required": true,
      "prompt": "Welchen Kinderwagen sucht ihr?",
      "help": "So vergleichen wir nur Modelle derselben Produktart. Der aktuelle Daten-Pilot kann Kombi-Kinderwagen ab Geburt bereits belastbar einordnen.",
      "options": [
        { "value": "first_combo_from_birth", "label": "Kombi-Kinderwagen ab Geburt", "route": "supported" },
        { "value": "buggy", "label": "Buggy für ein älteres Kind", "route": "unsupported_buggy" },
        { "value": "travel_buggy", "label": "Reisebuggy – leicht und kompakt", "route": "unsupported_travel_buggy" },
        { "value": "siblings_twins", "label": "Geschwister- oder Zwillingswagen", "route": "unsupported_siblings" },
        { "value": "unsure", "label": "Noch unsicher", "route": "scope_help" }
      ]
    },
    {
      "id": "daily_context",
      "order": 1,
      "type": "multi_choice",
      "required": true,
      "prompt": "Was prägt euren Alltag mit dem Kinderwagen?",
      "help": "Wählt alles, was regelmäßig vorkommt – höchstens drei Punkte. „Nichts davon“ kann nicht mit anderen Antworten kombiniert werden.",
      "showWhen": { "questionId": "search_goal", "operator": "equals", "value": "first_combo_from_birth" },
      "validation": {
        "minimumSelections": 1,
        "maximumSelections": 3,
        "exclusiveOptions": ["none_special"],
        "exclusiveGroups": [["regular_car", "small_trunk"]]
      },
      "options": [
        { "value": "regular_carrying", "label": "Treppen oder häufiges Tragen" },
        { "value": "regular_car", "label": "Regelmäßig im Auto · Platz eher okay" },
        { "value": "small_trunk", "label": "Regelmäßig im Auto · Platz eher knapp" },
        { "value": "regular_transit", "label": "Oft mit Bus und Bahn" },
        { "value": "tight_access", "label": "Schmaler Aufzug oder enge Tür" },
        { "value": "none_special", "label": "Nichts davon ist besonders wichtig" }
      ]
    },
    {
      "id": "lift_unit",
      "order": 2,
      "type": "single_choice",
      "required": true,
      "prompt": "Was müsst ihr meistens tragen?",
      "help": "Damit vergleichen wir dieselbe Einheit. Ist es noch unklar, nutzen wir das dokumentierte Gewicht der alltagstypischen Konfiguration als vorsichtigen Proxy.",
      "showWhen": { "questionId": "daily_context", "operator": "contains", "value": "regular_carrying" },
      "options": [
        { "value": "frame_only", "label": "Nur das Gestell" },
        { "value": "frame_with_seat", "label": "Gestell mit Sitzeinheit" },
        { "value": "frame_with_carrycot", "label": "Gestell mit Babywanne" },
        { "value": "unknown", "label": "Noch nicht sicher" }
      ]
    },
    {
      "id": "terrain",
      "order": 3,
      "type": "multi_choice",
      "required": true,
      "prompt": "Wo seid ihr regelmäßig unterwegs?",
      "help": "Wählt ein bis zwei typische Untergründe.",
      "showWhen": { "questionId": "daily_context", "operator": "answered" },
      "validation": { "minimumSelections": 1, "maximumSelections": 2 },
      "options": [
        { "value": "smooth_city", "label": "Glatte Gehwege und Stadt" },
        { "value": "cobblestone", "label": "Kopfsteinpflaster und schlechte Gehwege" },
        { "value": "gravel_park", "label": "Schotter und Parkwege" },
        { "value": "forest_field", "label": "Wald- und Feldwege" },
        { "value": "mixed", "label": "Ein ausgewogener Mix" }
      ]
    },
    {
      "id": "budget",
      "order": 4,
      "type": "budget",
      "required": true,
      "prompt": "Wie hoch ist euer Gesamtbudget?",
      "help": "Gemeint ist die benötigte Konfiguration inklusive Babywanne. Wählt direkt darunter, ob das Budget eine feste Grenze oder nur Orientierung ist.",
      "showWhen": { "questionId": "terrain", "operator": "answered" },
      "validation": { "currency": "EUR", "minimum": 300, "maximum": 2000, "step": 50, "suggested": 900 },
      "budgetModes": [
        { "value": "strict", "label": "Feste Obergrenze" },
        { "value": "orientation", "label": "Orientierung – gute Treffer darüber zeigen" }
      ],
      "defaultBudgetMode": "strict",
      "output": { "criterionId": "total_required_price", "field": "maximumBudgetEur" }
    },
    {
      "id": "top_priorities",
      "order": 5,
      "type": "multi_choice",
      "required": true,
      "prompt": "Welche zwei Eigenschaften entscheiden für euch?",
      "help": "Genau zwei. Alltag, Untergrund und Budget berücksichtigen wir bereits automatisch.",
      "showWhen": { "questionId": "budget", "operator": "answered" },
      "validation": { "minimumSelections": 2, "maximumSelections": 2 },
      "options": [
        { "value": "easy_to_carry", "label": "Möglichst leicht zu tragen", "criteriaIds": ["frequent_carrying_fit"] },
        { "value": "compact_in_car", "label": "Kompakt im Auto", "criteriaIds": ["car_transport_fit"] },
        { "value": "easy_folding", "label": "Einfach zu falten", "criteriaIds": ["folding_convenience"] },
        { "value": "storage", "label": "Viel gut nutzbarer Stauraum", "criteriaIds": ["storage_capacity"] },
        { "value": "long_use", "label": "Flexibel über mehrere Nutzungsphasen", "criteriaIds": ["long_term_flexibility"] },
        { "value": "service", "label": "Ersatzteile und Reparaturmöglichkeiten", "criteriaIds": ["repairability_service"] },
        { "value": "weather", "label": "Guter Wetter- und Sonnenschutz", "criteriaIds": ["weather_protection"] }
      ]
    }
  ]
}
