# www → non-www (falls nicht im Netlify-Dashboard konfiguriert)
https://www.kleinkind-welt.de/* https://kleinkind-welt.de/:splat 301!

# /404 direkt aufgerufen → echten HTTP 404 zurückgeben (kein Soft-404)
/404  /404.html  404

# API-Endpunkte
/api/newsletter-signup /.netlify/functions/newsletter-signup 200

# Umbenannter Artikel: holzspielzeug-kleinkind → holzspielzeug-vs-plastikspielzeug
/artikel/holzspielzeug-kleinkind     /artikel/holzspielzeug-vs-plastikspielzeug 301!
/artikel/holzspielzeug-kleinkind.html /artikel/holzspielzeug-vs-plastikspielzeug 301!

# Artikel .html → clean URLs (ohne .html)
/artikel/*.html /artikel/:splat 301!

# Root-Level .html → clean (für Impressum, Datenschutz, Über uns)
/impressum.html  /impressum  301!
/datenschutz.html /datenschutz 301!
/ueber-uns.html /ueber-uns 301!
/bewertungsmethode.html /bewertungsmethode 301!
/newsletter-bestaetigt.html /newsletter-bestaetigt 301!
